# PhishGuard — Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# VirusTotal — free key at https://www.virustotal.com/gui/join-us
# Free tier: 4 req/min, 500 req/day
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Database
# Development (SQLite, zero setup): leave this commented out
# Production (PostgreSQL): uncomment and fill in
# DATABASE_URL=postgresql://phishguard_user:yourpassword@localhost:5432/phishguard

# PhishTank API key (for dataset download)
# Register at https://phishtank.com/develop/index.php
PHISHTANK_API_KEY=your_phishtank_api_key_here
